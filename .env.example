# TDX API Keys (server-only — never expose to the browser!)
# Register at https://tdx.transportdata.tw/ to get these keys.
# On Vercel: set as Environment Variables (not prefixed with VITE_).
# Locally: copy this file to .env and fill in your values.
TDX_CLIENT_ID=""
TDX_CLIENT_SECRET=""

# (Optional) Express server port for local development
# PORT=3000

# (Optional) Comma-separated allowed origins for Socket.IO CORS
# ALLOWED_ORIGINS=""

# (Optional) Trust reverse-proxy X-Forwarded-For headers (set to "1" if behind a proxy)
# TRUST_PROXY=""
